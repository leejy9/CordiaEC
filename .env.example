# CordiaEC Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration (Required)
# For Supabase: Get this from your Supabase project dashboard
# Go to: Supabase Dashboard > Your Project > Connect > Connection string > Transaction pooler
# Replace [YOUR-PASSWORD] with your actual database password
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Application Configuration
NODE_ENV=production
PORT=5000

# Optional: For development
# NODE_ENV=development